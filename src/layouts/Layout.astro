---
import '../styles/global.css'
import { SITE } from '../lib/config'

interface Props {
  title?: string
  description?: string
}

const { title = `${SITE.name} — ${SITE.tagline}`, description = `${SITE.tagline}. Handcrafted in ${SITE.location}. Shop online or find us at local markets.` } = Astro.props
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex, nofollow" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://images.unsplash.com/photo-1519741497674-611481863552?w=1200<meta property="og:description" content={description} />q=80" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://images.unsplash.com" />
</head>
<body class="bg-cream text-charcoal antialiased">
  <!-- Nav -->
  <nav class="sticky top-0 z-50 bg-cream/95 backdrop-blur-sm border-b border-sage/10">
    <div class="mx-auto max-w-6xl flex items-center justify-between px-6 py-4">
      <a href="/" class="text-xl tracking-wide text-charcoal"><span class="text-sage-dark font-medium">Wren</span> & Fable</a>
      <div class="hidden md:flex items-center gap-6 text-sm">
        <a href="#shop" class="text-muted hover:text-sage-dark transition-colors">Shop</a>
        <a href="#markets" class="text-muted hover:text-sage-dark transition-colors">Markets</a>
        <a href="#custom" class="text-muted hover:text-sage-dark transition-colors">Custom Orders</a>
        <a href="#about" class="text-muted hover:text-sage-dark transition-colors">About</a>
        <a href="#shop" class="rounded-full bg-sage px-5 py-2 font-medium text-cream hover:bg-sage-dark transition-colors" style="font-family: system-ui, sans-serif;">Shop Now</a>
      </div>
      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden text-charcoal p-2" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu overlay -->
  <div id="mobile-menu" class="fixed inset-0 z-[60] bg-cream/95 backdrop-blur-sm hidden flex-col items-center justify-center gap-6 text-lg">
    <button id="mobile-menu-close" class="absolute top-6 right-6 text-charcoal p-2" aria-label="Close menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <a href="#shop" class="text-muted hover:text-sage-dark transition-colors">Shop</a>
    <a href="#markets" class="text-muted hover:text-sage-dark transition-colors">Markets</a>
    <a href="#custom" class="text-muted hover:text-sage-dark transition-colors">Custom Orders</a>
    <a href="#about" class="text-muted hover:text-sage-dark transition-colors">About</a>
    <a href="#shop" class="rounded-full bg-sage px-6 py-3 font-medium text-cream hover:bg-sage-dark transition-colors" style="font-family: system-ui, sans-serif;">Shop Now</a>
  </div>

  <main>
    <slot />
  </main>

  <!-- Demo Disclaimer -->
  <div class="bg-yellow-50 border-y border-yellow-200 py-3 px-6 text-center">
    <p class="text-xs text-yellow-800">
      <strong>Portfolio Demo</strong> — This is a fictional business created by <a href="https://upstate-web.com" class="underline hover:text-yellow-900">Upstate Web Co</a>. All names, locations, and details are entirely fictional.
    </p>
  </div>

  <!-- Footer -->
  <footer class="border-t border-sage/10 bg-warm">
    <div class="mx-auto max-w-6xl px-6 py-10">
      <div class="grid md:grid-cols-3 gap-8">
        <div>
          <p class="text-lg tracking-wide"><span class="text-sage-dark font-medium">Wren</span> & Fable</p>
          <p class="text-sm text-muted mt-2">{SITE.tagline}</p>
          <p class="text-sm text-muted mt-1">{SITE.location}</p>
        </div>
        <div class="text-sm text-muted">
          <p class="font-medium text-charcoal mb-2" style="font-family: system-ui, sans-serif;">Quick Links</p>
          <div class="space-y-1">
            <p><a href="#shop" class="hover:text-sage-dark">Shop</a></p>
            <p><a href="#markets" class="hover:text-sage-dark">Market Schedule</a></p>
            <p><a href="#custom" class="hover:text-sage-dark">Custom Orders</a></p>
            <p><a href="#about" class="hover:text-sage-dark">Our Story</a></p>
          </div>
        </div>
        <div class="text-sm text-muted">
          <p class="font-medium text-charcoal mb-2" style="font-family: system-ui, sans-serif;">Contact</p>
          <p><a href={`mailto:${SITE.email}`} class="hover:text-sage-dark">{SITE.email}</a></p>
          <p class="mt-1">{SITE.phone}</p>
          <div class="flex gap-3 mt-4">
            <a href="#" class="text-muted hover:text-sage-dark" aria-label="Instagram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
            <a href="#" class="text-muted hover:text-sage-dark" aria-label="Facebook">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385h-3.047v-3.47h3.047v-2.642c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953h-1.513c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385c5.738-.9 10.125-5.864 10.125-11.854z"/></svg>
            </a>
          </div>
        </div>
      </div>
      <div class="mt-8 pt-6 border-t border-sage/10 text-center text-xs text-muted">
        &copy; {new Date().getFullYear()} {SITE.name}. All rights reserved. Handmade in {SITE.location}.
        <span class="mx-2">|</span>
        <span>Built by <a href="https://upstate-web.com" class="text-sage hover:underline">Upstate Web Co</a></span>
      </div>
    </div>
  </footer>

  <!-- Inline AI: contextual search bar in hero, not a floating bubble -->

  <script>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const close = document.getElementById('mobile-menu-close');
    btn?.addEventListener('click', () => menu?.classList.replace('hidden', 'flex'));
    close?.addEventListener('click', () => menu?.classList.replace('flex', 'hidden'));
    menu?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu?.classList.replace('flex', 'hidden')));
  </script>
</body>
</html>
